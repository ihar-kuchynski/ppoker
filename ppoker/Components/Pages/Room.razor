@page "/room/{RoomId}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Microsoft.AspNetCore.SignalR.Client
@using ppoker.Data.Models
@using ppoker.Components.Poker
@implements IAsyncDisposable
@inject NavigationManager Navigation

<PageTitle>@(roomState?.RoomName ?? "Room") - Planning Poker</PageTitle>

@if (!isConnected)
{
    <div class="container mt-5 text-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Connecting...</span>
        </div>
        <p class="mt-3">Connecting to room...</p>
    </div>
}
else if (roomState is null)
{
    <div class="container mt-5">
        <div class="alert alert-danger">
            <h4>Room not found</h4>
            <p>The room you're trying to join doesn't exist or has been closed.</p>
            <a href="/" class="btn btn-primary">Back to Lobby</a>
        </div>
    </div>
}
else
{
    <div class="container-fluid mt-3">
        <div class="row">
            <!-- Main area -->
            <div class="col-md-9">
                <!-- Room header -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h2>@roomState.RoomName</h2>
                        <small class="text-muted">Room ID: @roomState.RoomId</small>
                    </div>
                    <button class="btn btn-outline-secondary" @onclick="CopyRoomLink">
                        📋 Copy Invite Link
                    </button>
                </div>

                <!-- Story input (host only) -->
                @if (currentParticipant?.IsHost == true)
                {
                    <div class="mb-4">
                        <div class="input-group">
                            <input type="text" class="form-control" @bind="storyInput"
                                   placeholder="Enter story or task to estimate..." />
                            <button class="btn btn-outline-primary" @onclick="SetStory">
                                Set Story
                            </button>
                        </div>
                    </div>
                }

                <!-- Current story -->
                @if (!string.IsNullOrEmpty(roomState.CurrentStory))
                {
                    <div class="alert alert-info mb-4">
                        <strong>Currently estimating:</strong> @roomState.CurrentStory
                    </div>
                }

                <!-- Voting cards -->
                @if (!currentParticipant?.IsSpectator == true)
                {
                    <div class="mb-4">
                        <h5>Select your estimate:</h5>
                        <VoteCardDeck Deck="@roomState.Deck" SelectedValue="@selectedVote" IsRevealed="@roomState.IsRevealed"
                                      OnVoteSelected="OnVoteSelected" />
                    </div>
                }

                <!-- Results area -->
                @if (roomState.IsRevealed)
                {
                    <div class="card mb-4">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0">📊 Results</h5>
                        </div>
                        <div class="card-body">
                            <VoteResults Participants="@roomState.Participants" Votes="@roomState.Votes" />
                        </div>
                    </div>
                }

                <!-- Host controls -->
                @if (currentParticipant?.IsHost == true)
                {
                    <div class="d-flex gap-2">
                        <button class="btn btn-success" @onclick="RevealVotes"
                                disabled="@(roomState.IsRevealed || !HasAnyVotes)">
                            👁️ Reveal Votes
                        </button>
                        <button class="btn btn-warning" @onclick="ResetRound">
                            🔄 New Round
                        </button>
                    </div>
                }
            </div>

            <!-- Sidebar: Participants -->
            <div class="col-md-3">
                <ParticipantList Participants="@roomState.Participants" Votes="@roomState.Votes"
                                 IsRevealed="@roomState.IsRevealed" CurrentParticipantId="@currentParticipant?.Id" />
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public string RoomId { get; set; } = string.Empty;

    [SupplyParameterFromQuery(Name = "name")]
    public string? UserName { get; set; }

    [SupplyParameterFromQuery(Name = "spectator")]
    public bool IsSpectator { get; set; }

    private HubConnection? hubConnection;
    private RoomState? roomState;
    private ParticipantState? currentParticipant;
    private string? selectedVote;
    private string storyInput = string.Empty;
    private bool isConnected;

    private bool HasAnyVotes => roomState?.Participants.Any(p => p.HasVoted) ?? false;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(UserName))
        {
            Navigation.NavigateTo($"/?roomId={RoomId}");
            return;
        }

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/pokerhub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<RoomState>("RoomUpdated", (state) =>
        {
            roomState = state;
            currentParticipant = state.Participants.FirstOrDefault(p => p.Id == currentParticipant?.Id);

            // Clear selected vote if round was reset
            if (!state.IsRevealed && !state.Votes.ContainsKey(currentParticipant?.Id ?? ""))
            {
                selectedVote = null;
            }

            InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
        isConnected = true;

        roomState = await hubConnection.InvokeAsync<RoomState?>("JoinRoom", RoomId, UserName, IsSpectator);

        if (roomState is not null)
        {
            // Find our participant in the list (we're the most recently joined)
            currentParticipant = roomState.Participants.LastOrDefault();
        }
    }

    private async Task OnVoteSelected(string vote)
    {
        if (hubConnection is null || currentParticipant is null || roomState?.IsRevealed == true)
            return;

        selectedVote = vote;
        await hubConnection.InvokeAsync("CastVote", RoomId, currentParticipant.Id, vote);
    }

    private async Task RevealVotes()
    {
        if (hubConnection is null) return;
        await hubConnection.InvokeAsync("RevealVotes", RoomId);
    }

    private async Task ResetRound()
    {
        if (hubConnection is null) return;
        selectedVote = null;
        await hubConnection.InvokeAsync("ResetRound", RoomId, null);
    }

    private async Task SetStory()
    {
        if (hubConnection is null || string.IsNullOrWhiteSpace(storyInput)) return;
        await hubConnection.InvokeAsync("SetStory", RoomId, storyInput);
        storyInput = string.Empty;
    }

    private async Task CopyRoomLink()
    {
        // This would need JS interop for clipboard - simplified for now
        await Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.InvokeAsync("LeaveRoom", RoomId);
            await hubConnection.DisposeAsync();
        }
    }
}